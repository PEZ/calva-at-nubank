{:paths ["scripts"]
 :deps  {org.babashka/cli {:mvn/version "0.2.23"}}
 :tasks
 {:requires ([babashka.cli :as cli]
             [dependencies-sync])

  localize  {:doc  "Sync Joyride files and Copilot skills from global to workspace. Results written to .tmp/dependencies-sync-result.edn"
             :task (dependencies-sync/sync!
                    (assoc (cli/parse-opts *command-line-args*)
                           :direction :localize))}

  globalize {:doc  "Sync Joyride files and Copilot skills from workspace to global. Results written to .tmp/dependencies-sync-result.edn"
             :task (dependencies-sync/sync!
                    (assoc (cli/parse-opts *command-line-args*)
                           :direction :globalize))}}}

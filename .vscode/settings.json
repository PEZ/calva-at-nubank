{
  "markdown.preview.fontSize": 22,
  "markdown.styles": [
    "next-slide.css"
  ],
  "window.zoomLevel": 2,
  "editor.fontSize": 24,
  "markdown.preview.lineHeight": 1.5,
  "calva.customREPLCommandSnippets": [
    {
      "name": "Load Epupp Manifest",
      "snippet": "(epupp.repl/manifest! $top-level-form)"
    },
    {
      "name": "Upload current Epupp userscript",
      "snippet": "(epupp.fs/save! ${file-text|pr-str} {:fs/force? true})"
    },
    {
      "key": "t",
      "name": "Test Current Var",
      "snippet": "(clojure.test/test-var #'$top-level-defined-symbol)"
    },
    {
      "key": "r",
      "name": "(clojure.test/run-tests)",
      "snippet": "(require 'clojure.test) (clojure.test/run-tests)"
    },
    {
      "key": "a",
      "name": "Add selected dependency/ies",
      "snippet": "(require '[clojure.repl.deps :refer [add-libs]]) (add-libs '{$selection})"
    },
    {
      "key": "c",
      "name": "Tap Current Form",
      "snippet": "(tap> $current-form)"
    },
    {
      "key": "l",
      "name": "Toggle Line Numbers",
      "snippet": "(set! (.-lineNumbers vscode/window.activeTextEditor.options) ({1 0 0 1} (.-lineNumbers vscode/window.activeTextEditor.options)))",
      "repl": "joyride"
    }
  ],
  "calva.customREPLHoverSnippets": [
    {
      "name": "Eval text on hover",
      "snippet": "(str :Hello_Nubank! \" $hover-text\")"
    }
  ],
  "calva.replConnectSequences": [
    {
      "name": "Shadow fullstack",
      "projectType": "deps.edn",
      "cljsType": "shadow-cljs",
      "projectRootPath": [
        "projects",
        "shadow-w-backend"
      ],
      "replSessionNames": {
        "primary": "backend",
        "secondary": "frontend"
      },
      "afterPrimaryReplConnectedCode": [
        "(println :renamed-primary-to-backend)",
        "(println :renamed-secondary-to-frontend)"
      ],
      "menuSelections": {
        "cljAliases": [
          "dev",
        ],
        "cljsLaunchBuilds": [
          "app",
        ],
        "cljsDefaultBuild": "app"
      }
    },
    {
      "name": "Epupp REPL",
      "projectType": "scittle",
      "fallbackPort": 3339,
      "replSessionNames": {
        "primary": "epupp"
      },
      "replSessionFilePatterns": {
        "primary": [
          "epupp-userscripts/**/*.cljs",
          "live-tampers/*.cljs",
        ]
      }
    },
    {
      "name": "Scittle Tic-Tac-Toe REPL",
      "projectType": "scittle",
      "fallbackPort": 1339,
      "replSessionNames": {
        "primary": "tic-tac-toe"
      },
      "replSessionFilePatterns": {
        "primary": [
          ".joyride/src/scittle-replicant-tic-tac-toe/resources/scittle/**/core.cljs",
        ]
      }
    },
    {
      "name": "pirate-lang",
      "projectType": "deps.edn",
      "projectRootPath": [
        "projects",
        "pirate-lang"
      ],
      "cljsType": "none",
      "replSessionNames": {
        "primary": "pirate-lang"
      },
      "menuSelections": {
        "cljAliases": [
          "allow-attach-self",
          "dev",
          "test"
        ]
      }
    },
    {
      "name": "Docker REPL (pirate-lang)",
      "projectType": "deps.edn",
      "projectRootPath": [
        "projects",
        "pirate-lang"
      ],
      "customJackInCommandLine": "bb docker-repl",
      "cljsType": "none",
      "replSessionNames": {
        "primary": "pirate-lang-docker"
      },
      "menuSelections": {
        "cljAliases": [
          "allow-attach-self",
          "dev",
          "test"
        ]
      }
    },
  ],
  "zenMode.hideStatusBar": false,
  "zenMode.hideLineNumbers": true,
  "chat.promptFilesLocations": {
    "~/.copilot/prompts": true
  }
}